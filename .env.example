# Clawspan — Environment Configuration
# ─────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your keys below
# 3. Never commit .env to git (it's in .gitignore)
#
# Run `clawspan keys` at any time to re-edit this file.

# ── LLM Providers ──────────────────────────────────────────────────────────

# DeepSeek — primary brain for all agents and voice responses
# Get key → platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI — MemPalace embeddings (text-embedding-3-small)
# Get key → platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — optional, Claude agent delegation path
# Get key → console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Voice Stack ─────────────────────────────────────────────────────────────

# Deepgram — speech-to-text (STT)
# Get key → console.deepgram.com  → Create API Key
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cartesia — text-to-speech (TTS)
# Get key → play.cartesia.ai → API Keys
CARTESIA_API_KEY=your_cartesia_api_key_here

# Cartesia Voice ID — leave blank to use the default British voice
# Browse voices → play.cartesia.ai → Voice Library
CARTESIA_VOICE_ID=

# ── External Tools ──────────────────────────────────────────────────────────

# Tavily — deep web research
# Get key → app.tavily.com → API Keys
TAVILY_API_KEY=your_tavily_api_key_here

# GitHub — personal access token
# Get key → github.com/settings/tokens → Generate new token (classic)
# Required scopes: repo, read:user, read:org
GITHUB_TOKEN=your_github_token_here

# ── Google OAuth (Gmail + Calendar) ────────────────────────────────────────
# Setup guide → console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Add redirect URI: http://localhost:8080
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── AWS — Infrastructure Monitoring (optional) ──────────────────────────────
# IAM user with ReadOnlyAccess is sufficient
# Get keys → AWS Console → IAM → Users → Security credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=ap-south-1

# ── Dev Flags ───────────────────────────────────────────────────────────────
# Uncomment to bypass the passphrase gate during development
# CLAWSPAN_SKIP_AUTH=1
