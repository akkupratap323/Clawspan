# JARVIS — environment configuration template
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── LLM providers ───────────────────────────────────────────────────────
# DeepSeek (primary — used by all agents and the main voice LLM)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (used for MemPalace embeddings: text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (optional — used by the Claude agent delegation path)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Voice stack ─────────────────────────────────────────────────────────
# Deepgram — speech-to-text
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Cartesia — text-to-speech
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_cartesia_voice_id_here

# ── External tools ──────────────────────────────────────────────────────
# Tavily — deep web research
TAVILY_API_KEY=your_tavily_api_key_here

# GitHub — personal access token with repo, read:user, read:org scopes
GITHUB_TOKEN=your_github_token_here

# Google OAuth — Gmail + Calendar integration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── AWS (infrastructure monitoring) ─────────────────────────────────────
# IAM user with ReadOnlyAccess policy is sufficient
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=ap-south-1

# ── Dev flags (optional) ────────────────────────────────────────────────
# Skip voice passphrase gate during development
# JARVIS_SKIP_AUTH=1
